# Copy this file to .env for local testing (never commit .env to git)
# In GitHub Actions these are stored as repository Secrets instead.

# Your Zendesk login email
ZENDESK_EMAIL=you@cloudsecurityalliance.org

# Zendesk API token
# Admin Center → Apps & Integrations → APIs → Zendesk API → Add API token
ZENDESK_TOKEN=your_zendesk_api_token_here

# Gmail address the report is sent FROM
GMAIL_FROM=you@gmail.com

# Gmail App Password (NOT your regular password)
# Google Account → Security → 2-Step Verification → App Passwords → Generate
# Select app: Mail  |  Select device: Other (name it "IT Ops Report")
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Who receives the report — comma-separated for multiple recipients
GMAIL_TO=cvee@cloudsecurityalliance.org
